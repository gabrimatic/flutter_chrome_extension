{
  "manifest_version": 3,
  "name": "Flutter Chrome Extension",
  "short_name": "Flutter MV3",
  "description": "Manifest V3 Chrome extension popup built with Flutter Web.",
  "version": "1.1.0",
  "version_name": "1.1.0",
  "minimum_chrome_version": "88",
  "homepage_url": "https://github.com/gabrimatic/flutter_chrome_extension",
  "icons": {
    "16": "icons/Icon-16.png",
    "32": "icons/Icon-32.png",
    "48": "icons/Icon-48.png",
    "128": "icons/Icon-128.png",
    "192": "icons/Icon-192.png",
    "512": "icons/Icon-512.png"
  },
  "action": {
    "default_title": "Flutter Chrome Extension",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/Icon-16.png",
      "32": "icons/Icon-32.png",
      "48": "icons/Icon-48.png",
      "128": "icons/Icon-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
